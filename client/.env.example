# Backend API (dev: leave empty to use Vite proxy, or set http://localhost:3000)
VITE_API_BASE_URL=

# Socket.io (dev: leave empty to use Vite proxy)
VITE_SOCKET_URL=

# Public customer-facing site URL (must match server CLIENT_URL in each environment)
# Development:
VITE_APP_URL=http://localhost:5173
# Production example:
# VITE_APP_URL=https://yourdomain.com
